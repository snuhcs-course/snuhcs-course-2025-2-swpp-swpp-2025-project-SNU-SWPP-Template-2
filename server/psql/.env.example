# Database Configuration
# Copy this file to .env and fill in your actual values

# PostgreSQL Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=foodigram
DB_USER=postgres
DB_PASSWORD=postgres

# OpenAI API Configuration (required for preprocess.py and test.py)
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Embedding Model Configuration
# HuggingFace model for Korean text embeddings
EMBEDDING_MODEL_NAME=BM-K/KoSimCSE-roberta
EMBEDDING_MAX_LENGTH=512
EMBEDDING_BATCH_SIZE=32

# Clustering Configuration
CLUSTERING_METHOD=spectral

# HDBSCAN Parameters
HDBSCAN_MIN_CLUSTER_SIZE=3
HDBSCAN_MIN_SAMPLES=1
HDBSCAN_CLUSTER_SELECTION_EPSILON=0.3

# Spectral Clustering Parameters
SPECTRAL_MAX_CLUSTERS=8
SPECTRAL_CLUSTER_DIVISOR=8
SPECTRAL_N_NEIGHBORS=10

# KMeans Clustering Parameters
KMEANS_MAX_CLUSTERS=15
KMEANS_CLUSTER_DIVISOR=6
KMEANS_N_INIT=20
KMEANS_MAX_ITER=500

# Similarity Clustering Fallback
SIMILARITY_THRESHOLD_DEFAULT=0.7
SIMILARITY_THRESHOLD_AGGRESSIVE=0.4

# LLM Configuration
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=500
LLM_BATCH_SIZE=20

# Optional: Set Python environment
PYTHONPATH=.

# Development settings
DEBUG=True