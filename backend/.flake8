[flake8]
# Maximum line length (PEP 8 standard)
max-line-length = 79

# Maximum cyclomatic complexity
max-complexity = 10

# Ignore specific error codes
# E203: whitespace before ':' (conflicts with Black)
# W503: line break before binary operator (conflicts with Black)
extend-ignore = E203, W503

# Exclude directories
exclude =
    .git,
    __pycache__,
    .venv,
    venv,
    .eggs,
    *.egg,
    build,
    dist,
    migrations,
    .tox,
    .pytest_cache,
    htmlcov,
    *.pyc

# Count errors
count = True

# Show source code for each error
show-source = True

# Show statistics at the end
statistics = True

# Enable docstring checks (requires flake8-docstrings)
docstring-convention = google

# Per-file ignores
per-file-ignores =
    # Allow unused imports in __init__.py
    __init__.py:F401
    # Allow module-level imports not at top in specific files
    */asgi.py:E402
    */settings.py:E402
    */debug_auth.py:E402,F401
    test_*.py:E402,F401,F841
    */tests/*:E402,F401,F841,E722
    # Ignore unused imports in admin.py (often used for registration)
    */admin.py:F401
    # Ignore unused imports in views.py and tests.py stubs
    */views.py:F401
    */tests.py:F401
